# ClientTrack CRM+ Environment Variables Example
# 
# Instructions:
# 1. Copy this file and rename it to `.env`
# 2. Fill in the values for your local or production environment.
# 3. DO NOT COMMIT the actual `.env` file to version control.

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================
# [Required] Database connection settings.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clienttrackdb
DB_USER=postgres
DB_PASS=your_db_password_here

# [Optional] For internal postgres exporter monitoring
POSTGRES_EXPORTER_DSN=postgresql://postgres:your_db_password_here@localhost:5432/clienttrackdb?sslmode=disable

# ==============================================================================
# Security / JWT Authentication
# ==============================================================================
# [Required] Secret keys for encoding JWT tokens. Must be a strong random string in production.
SECRET_KEY=generate_a_strong_random_secret_string_here
ALGORITHM=HS256

# [Required] Token expiration time in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# [Required] Separated secret key for the refresh token logic.
REFRESH_TOKEN_SECRET_KEY=generate_another_strong_random_secret_string_here


# ==============================================================================
# Email (SendGrid)
# ==============================================================================
# [Optional] Required if you want email verification, forgot password, or notifications to work.
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_SENDER=no-reply@yourdomain.com


# ==============================================================================
# Storage (Supabase)
# ==============================================================================
# [Required] For object storage (avatars, attachments).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# [Optional] App Logo for email templates.
APP_LOGO_URL=https://your-project.supabase.co/storage/v1/object/public/assets/app-icon/logo.webp

# [Required] Bucket names exactly as created in Supabase.
SUPABASE_AVATAR_BUCKET=private-user-avatars
SUPABASE_ATTACHMENT_BUCKET=private-client-attachments


# ==============================================================================
# AI (OpenRouter)
# ==============================================================================
# [Optional] Required for AI generated insights or drafting emails.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=mistralai/mistral-7b-instruct


# ==============================================================================
# Redis (Caching & Job Queues)
# ==============================================================================
# [Required] Redis connection details for caching.
REDIS_HOST=localhost
REDIS_PORT=6379


# ==============================================================================
# Monitoring (Grafana & Elasticsearch)
# ==============================================================================
# [Optional] For APM and server monitoring.
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password
ELASTICSEARCH_URL=http://localhost:9200


# ==============================================================================
# Application / API Constraints
# ==============================================================================
# [Required] Comma separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================================================
# Payments (Stripe)
# ==============================================================================
# [Optional] Required only if subscription logic is enabled.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...
