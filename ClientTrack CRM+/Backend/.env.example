# Database (PostgreSQL)
# -------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clienttrackdb
DB_USER=postgres
DB_PASS=postgres


# Security / JWT
# -------------------------------------------------
SECRET_KEY=change_me_please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_SECRET_KEY=change_me_refresh_secret


# Email (SendGrid)
# -------------------------------------------------
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_SENDER=no-reply@example.com


# Storage (Supabase)
# -------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_APP_LOGO_URL=https://your-project.supabase.co/storage/v1/object/public/assets/app-icon/logo.webp
SUPABASE_AVATAR_BUCKET=private-user-avatars
SUPABASE_ATTACHMENT_BUCKET=private-client-attachments


# AI (OpenRouter)
# -------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=mistralai/mistral-7b-instruct


# Redis
# -------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379


# Monitoring (Grafana & Elasticsearch)
# -------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
ELASTICSEARCH_URL=http://localhost:9200


# CORS
# -------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
